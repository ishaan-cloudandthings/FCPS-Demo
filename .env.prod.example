# Production Environment Variables for Docker Deployment
# Copy this to .env.prod and fill in with real production values

# ID.me OAuth (Production Sandbox)
IDME_CLIENT_ID=your_production_client_id
IDME_CLIENT_SECRET=your_production_client_secret
IDME_REDIRECT_URI=https://your-prod-domain.com/verification/callback

# JWT Secret (Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY=your_generated_jwt_secret_key_here

# Oracle Database (Production)
ORACLE_HOST=your-oracle-host.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_USER=prod_oracle_user
ORACLE_PASSWORD=prod_oracle_password
