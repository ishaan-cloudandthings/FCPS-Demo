# --- Secrets ---------------------------------------------------------------
# `.env` may contain ID.me sandbox creds, JWT secrets, Oracle credentials,
# etc. Real values must NEVER be committed. The template lives in
# `backend/.env.example`.
.env
.env.local
.env.*.local
backend/.env
backend/.env.local
backend/.env.*.local

