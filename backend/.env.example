# FCPS Procurement Portal — environment template.
#
# ===========================================================================
# THIS FILE IS A TEMPLATE. It must NEVER contain real secrets.
# ===========================================================================
#
# Demo mode (ENVIRONMENT=dev) has built-in defaults for every required
# field, so the backend boots from a fresh `git clone` with **no .env at
# all** — see backend/app/core/config.py and
# docs/decision-log/demo-zero-config-boot.md.
#
# Copy this file to `.env` ONLY when you need to override something
# (real ID.me sandbox creds, a generated JWT secret, real Oracle creds, etc.).
# `.env` is gitignored.

# --- ID.me OAuth (sandbox per ADR-007) -------------------------------------
# Leave blank to use demo defaults that won't actually authenticate against
# id.me — the demo persona panel doesn't need ID.me.
IDME_CLIENT_ID=
IDME_CLIENT_SECRET=
IDME_AUTHORIZE_URL=https://api.id.me/oauth/authorize
IDME_TOKEN_URL=https://api.id.me/oauth/token
IDME_JWKS_URL=https://api.id.me/.well-known/jwks.json
IDME_ISSUER=https://api.id.me
IDME_REDIRECT_URI=http://localhost:5173/verification/callback
IDME_SCOPE=openid email

# --- Application -----------------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO

# --- JWT session (per ADR-004) — used by AC-8 ------------------------------
# Demo mode uses a built-in placeholder (see _DEMO_JWT_SECRET in config.py).
# For any non-dev environment, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_TTL_HOURS=4
JWT_COOKIE_SECURE=false

# --- Oracle (per AC-11 / NFR-17) — used by `oracle_service` -----------------
# Demo defaults assume a local Oracle XE container on localhost:1521.
# Leave blank in dev to use the built-in demo defaults.
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_USER=
ORACLE_PASSWORD=
