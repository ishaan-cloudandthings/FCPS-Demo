# FCPS Procurement Portal — environment template.
# Copy to .env and fill in real values. .env is gitignored.

# --- ID.me OAuth (sandbox per ADR-007) -------------------------------------
# Used by AC-6 (POST /api/auth/login) and AC-7 (POST /api/auth/callback).
IDME_CLIENT_ID=placeholder
IDME_CLIENT_SECRET=placeholder
IDME_AUTHORIZE_URL=https://api.id.me/oauth/authorize
IDME_TOKEN_URL=https://api.id.me/oauth/token
IDME_JWKS_URL=https://api.id.me/.well-known/jwks.json
IDME_ISSUER=https://api.id.me
IDME_REDIRECT_URI=http://localhost:5173/verification/callback
IDME_SCOPE=openid email

# --- Application -----------------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO

# --- JWT session (per ADR-004) — used by AC-8 ------------------------------
# Minimum 32 characters (HS256 security floor). Generate one with e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_TTL_HOURS=4
JWT_COOKIE_SECURE=false

# --- Oracle (per AC-11 / NFR-17) — used by `oracle_service` -----------------
# Thin-mode `oracledb` only — no Oracle Client install required.
# Credentials must be supplied; no defaults so a missing value fails fast at boot.
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XE
ORACLE_USER=
ORACLE_PASSWORD=
